{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "OpenAI /v1/chat/completions response",
  "description": "Structural envelope for a non-streaming chat completion response. Asserts protocol conformance, not output quality.",
  "type": "object",
  "required": ["id", "object", "choices", "model"],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(chatcmpl-|chat-)"
    },
    "object": {
      "type": "string",
      "const": "chat.completion"
    },
    "created": {
      "type": "integer",
      "minimum": 0
    },
    "model": {
      "type": "string",
      "minLength": 1
    },
    "choices": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["index", "message", "finish_reason"],
        "properties": {
          "index": {"type": "integer", "minimum": 0},
          "message": {
            "type": "object",
            "required": ["role", "content"],
            "properties": {
              "role": {"type": "string", "enum": ["assistant", "system", "user", "tool", "function"]},
              "content": {"type": ["string", "null"]}
            }
          },
          "finish_reason": {
            "type": ["string", "null"],
            "enum": ["stop", "length", "content_filter", "tool_calls", "function_call", null]
          }
        }
      }
    },
    "usage": {
      "type": "object",
      "properties": {
        "prompt_tokens": {"type": "integer", "minimum": 0},
        "completion_tokens": {"type": "integer", "minimum": 0},
        "total_tokens": {"type": "integer", "minimum": 0}
      }
    }
  }
}
