{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "LLM Response Schema",
  "description": "Expected JSON structure for validated LLM inference responses",
  "type": "object",
  "properties": {
    "answer": {
      "type": "string",
      "description": "The generated answer text from the model"
    },
    "confidence": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0,
      "description": "Confidence score between 0 and 1"
    }
  },
  "required": ["answer", "confidence"],
  "additionalProperties": false
}
